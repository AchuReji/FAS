              </div>

              {/* Navigation List */}
              <div className="flex-1 overflow-y-auto">
                <ul className="py-2">
                  {navLinks.map((link) => (
                    <li key={link.name} className="px-6 py-4 flex justify-between items-center border-b border-white/5 hover:bg-white/5 cursor-pointer font-medium">
