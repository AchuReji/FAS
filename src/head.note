                  <div className="relative w-7 h-7">
                    <div className="absolute inset-0 bg-white transform -rotate-12 rounded-sm"></div>
                    <div className="absolute top-0.5 left-3 w-3 h-3 bg-[#C5D941] rounded-full"></div>
                  </div>
                  <span className="text-2xl font-bold">Consultez</span>
                </div>
                <button onClick={() => setIsMenuOpen(false)} className="bg-white/10 p-2 hover:bg-white/20 transition-colors">
