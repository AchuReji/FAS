      {/* --- DESKTOP TOP BAR --- */}
      <div className="hidden lg:flex items-center justify-between border-b border-gray-100 px-4 xl:px-20 py-2 text-[13px] text-gray-700">
        <div className="flex items-center gap-6">
          <div className="flex items-center gap-2 hover:text-[#C5D941] cursor-pointer transition-colors">
            <Mail size={14} className="text-[#004236]" />
            <span>needhelp@company.com</span>
          </div>
          <div className="flex items-center gap-2 border-l pl-6 border-gray-200">
            <MapPin size={14} className="text-[#004236]" />
            <span>6391 Elgin St. Celina, Delaware 10299</span>
          </div>
        </div>
        
        <div className="flex items-center bg-[#C5D941] -mr-4 xl:-mr-20 h-10 px-8 relative">
          <div className="flex gap-5 mr-8 font-bold text-[#1A2E24]">
            <a href="#" className="hover:text-white transition-colors">About</a>
            <a href="#" className="hover:text-white transition-colors">Faqs</a>
            <a href="#" className="hover:text-white transition-colors">Contact</a>
          </div>
          <div className="flex gap-4 border-l border-black/10 pl-6">
