                <div className="p-4 flex justify-center border-r border-white/10 hover:bg-[#C5D941] hover:text-black transition-colors cursor-pointer"><Facebook size={18} /></div>
                <div className="p-4 flex justify-center border-r border-white/10 hover:bg-[#C5D941] hover:text-black transition-colors cursor-pointer"><Youtube size={18} /></div>
