                  <div className="flex items-start gap-4">
                    <Mail size={32} className="text-white mt-1" />
                    <div>
                      <p className="text-[#C5D941] text-xs font-bold tracking-widest mb-1">SEND EMAIL</p>
                      <p className="text-lg font-bold">help@company.com</p>
                    </div>
                  </div>

                  <div className="flex items-start gap-4">
                    <Clock size={32} className="text-white mt-1" />
